pipeline {
    agent any

    triggers {
        githubPush()
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-creds')
        IMAGE_NAME = "fraud_detection_devops"
        IMAGE_TAG = "${BUILD_NUMBER}"
        VAULT_ADDR = "http://vault:8200"
        EMAIL_TO = "atul9soni@gmail.com,sraghavtejas1808@gmail.com"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: "https://github.com/raghavtejas1808/fraud-detection-devops.git"
            }
        }

        stage('Fetch Secrets from Vault') {
            steps {
                sh '''
                    export VAULT_TOKEN=$(cat /run/secrets/vault_token)
                    export DB_PASSWORD=$(vault kv get -field=password secret/fraud-app/db)
                    echo "Secrets fetched successfully"
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'pip install -r app/requirements.txt'
            }
        }

        stage('Lint Code') {
            steps {
                sh 'flake8 app/ --max-line-length=120'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'cd app && python -m pytest test_main.py -v --tb=short'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build -t ${DOCKERHUB_CREDENTIALS_USR}/${IMAGE_NAME}:${IMAGE_TAG} ./app
                    docker tag ${DOCKERHUB_CREDENTIALS_USR}/${IMAGE_NAME}:${IMAGE_TAG} ${DOCKERHUB_CREDENTIALS_USR}/${IMAGE_NAME}:latest
                """
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_CREDENTIALS_USR --password-stdin
                    docker push ${DOCKERHUB_CREDENTIALS_USR}/${IMAGE_NAME}:${IMAGE_TAG}
                    docker push ${DOCKERHUB_CREDENTIALS_USR}/${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Deploy with Ansible') {
            steps {
                sh "ansible-playbook -i ansible/inventory.ini ansible/site.yml -e image_tag=${IMAGE_TAG} -e dockerhub_user=${DOCKERHUB_CREDENTIALS_USR}"
            }
        }
    }

    post {
        success {
            echo "Pipeline succeeded. Build #${BUILD_NUMBER} deployed."
            mail to: "${EMAIL_TO}",
                 subject: "SUCCESS: Jenkins Build #${BUILD_NUMBER} - fraud-detection-devops",
                 body: "Great news! Build #${BUILD_NUMBER} of fraud-detection-devops completed successfully and deployed.\n\nCheck console output at: ${BUILD_URL}"
        }
        failure {
            echo "Pipeline failed. Check logs."
            mail to: "${EMAIL_TO}",
                 subject: "FAILURE: Jenkins Build #${BUILD_NUMBER} - fraud-detection-devops",
                 body: "Warning! Build #${BUILD_NUMBER} of fraud-detection-devops failed during execution.\n\nCheck console output at: ${BUILD_URL}"
        }
    }
}
